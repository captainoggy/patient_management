# Copy to .env and adjust. Docker Compose reads variables from the shell or a .env file in this directory.
# See README: Authentication & tenancy (for reviewers).

# --- Django (API container / local backend) ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
# Comma-separated hosts (add your machine name if needed)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api

# HTTPS behind proxy (Render, etc.)
# DJANGO_HTTPS_DEPLOYMENT=true

# Single-clinic mode: lock API to this clinic primary key (optional)
# DJANGO_FIXED_CLINIC_ID=

# Trusted browser origins for CSRF (include Vite, nginx UI, and direct API :8000 for /admin)
# DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000,http://127.0.0.1:8000

# --- Database (Compose sets these; override locally if needed) ---
POSTGRES_DB=patient_mgmt
POSTGRES_USER=patient_mgmt
POSTGRES_PASSWORD=patient_mgmt
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Local SQLite instead of Postgres: set in shell, not necessarily here
# DJANGO_DB_ENGINE=sqlite

# --- Demo seed (Docker entrypoint: 1 = run seed_demo after migrate) ---
SEED_DEMO=1
