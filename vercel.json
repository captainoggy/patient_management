{
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "build": {
    "env": {
      "VITE_API_ROOT": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://patient-mgmt-api.onrender.com/api/:path*"
    }
  ]
}
